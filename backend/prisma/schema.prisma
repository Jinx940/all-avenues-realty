generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  DONE
  IN_PROGRESS
  PENDING
  PLANNING
}

enum PaymentStatus {
  PAID
  PARTIAL_PAYMENT
  UNPAID
  NOT_INVOICED_YET
}

enum InvoiceStatus {
  YES
  NO
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  ADMIN
  OFFICE
  WORKER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum FileCategory {
  BEFORE
  PROGRESS
  AFTER
  RECEIPT
  INVOICE
  QUOTE
}

enum GeneratedDocumentType {
  INVOICE
  QUOTE
}

enum DocumentOwner {
  AZE
  RYAN
  TODD
}

enum WorkerHistoryAction {
  ADDED
  DISABLED
  ENABLED
  DELETED
}

enum NemtDriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
}

enum NemtVehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum NemtTripStatus {
  NEW
  PENDING_CONFIRMATION
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  PROBLEM
  COMPLETED
  CANCELED
  NO_SHOW
}

enum NemtBroker {
  MTM
  OTHER
}

enum NemtExternalSystem {
  MTM
  ROUTINGBOX
  MANUAL
  OTHER
}

enum NemtInvoiceStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  PAID
}

enum NemtIncidentType {
  COMPLAINT
  ACCIDENT
  PASSENGER_ISSUE
  INTERNAL_NOTE
  OTHER
}

enum NemtIncidentStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum NemtDocumentType {
  DRIVER_LICENSE
  CPR_CERTIFICATION
  INSURANCE
  REGISTRATION
  VEHICLE_INSPECTION
  TRIP_SIGNATURE
  TRIP_DOCUMENTATION
  OTHER
}

enum NemtDocumentStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  MISSING
}

enum NemtMaintenanceType {
  ROUTINE
  REPAIR
  INSPECTION
  OTHER
}

model Property {
  id            String              @id @default(cuid())
  name          String              @unique
  address       String?
  cityLine      String?
  notes         String?
  coverImageUrl String?
  floors        Int?
  bedrooms      Int?
  bathrooms     Int?
  halfBathrooms Int?
  livingRooms   Int?
  diningRooms   Int?
  kitchens      Int?
  sunroom       Int?
  garages       Int?
  attic         Int?
  frontPorch    Int?
  backPorch     Int?
  floorGroups   Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  jobs          Job[]
  documents     GeneratedDocument[]
}

model Worker {
  id            String          @id @default(cuid())
  name          String          @unique
  status        WorkerStatus    @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User?
  driverProfile Driver?
  assignments   JobAssignment[]
  history       WorkerHistory[]
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  displayName  String
  passwordHash String
  role         UserRole      @default(WORKER)
  status       UserStatus    @default(ACTIVE)
  workerId     String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  worker       Worker?       @relation(fields: [workerId], references: [id], onDelete: SetNull)
  sessions     UserSession[]
  auditLogs    AuditLog[]

  @@index([role, status])
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Job {
  id             String          @id @default(cuid())
  propertyId     String
  story          String          @default("")
  unit           String          @default("")
  section        String
  area           String          @default("")
  service        String
  description    String          @default("")
  materialCost   Decimal         @default(0) @db.Decimal(12, 2)
  laborCost      Decimal         @default(0) @db.Decimal(12, 2)
  status         JobStatus       @default(PENDING)
  invoiceStatus  InvoiceStatus   @default(NO)
  paymentStatus  PaymentStatus   @default(NOT_INVOICED_YET)
  advanceCashApp Decimal         @default(0) @db.Decimal(12, 2)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assignments    JobAssignment[]
  files          JobFile[]

  @@index([propertyId])
  @@index([status])
  @@index([paymentStatus])
}

model JobAssignment {
  jobId      String
  workerId   String
  assignedAt DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Restrict)

  @@id([jobId, workerId])
  @@index([workerId])
}

model JobFile {
  id                  String             @id @default(cuid())
  jobId               String
  category            FileCategory
  originalName        String
  storedName          String?
  mimeType            String
  size                Int
  documentNumber      String?
  generatedDocumentId String?
  createdAt           DateTime           @default(now())
  job                 Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  generatedDocument   GeneratedDocument? @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)

  @@index([jobId, category])
  @@index([generatedDocumentId])
}

model ManagedFileBackup {
  id           String   @id @default(cuid())
  storedRef    String   @unique
  originalName String
  encoding     String   @default("identity")
  mimeType     String
  size         Int
  storedSize   Int      @default(0)
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GeneratedDocument {
  id             String                @id @default(cuid())
  propertyId     String
  documentType   GeneratedDocumentType
  owner          DocumentOwner
  documentNumber String
  fileName       String
  mimeType       String                @default("text/html")
  html           String
  issueDate      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  property       Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  files          JobFile[]

  @@unique([documentType, documentNumber])
  @@index([propertyId, documentType])
  @@index([issueDate, createdAt])
  @@index([owner, documentType, issueDate])
}

model WorkerHistory {
  id             String              @id @default(cuid())
  workerId       String?
  workerName     String
  action         WorkerHistoryAction
  previousStatus WorkerStatus?
  newStatus      WorkerStatus?
  performedBy    String              @default("Admin")
  notes          String?
  createdAt      DateTime            @default(now())
  worker         Worker?             @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([createdAt])
}

model AuditLog {
  id                String   @id @default(cuid())
  entityType        String
  entityId          String?
  entityLabel       String?
  action            String
  summary           String
  metadata          Json?
  performedByUserId String?
  performedByName   String
  createdAt         DateTime @default(now())
  performedByUser   User?    @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([performedByUserId])
}

model Driver {
  id               String           @id @default(cuid())
  workerId         String?          @unique
  firstName        String
  lastName         String
  displayName      String
  phone            String?
  email            String?
  status           NemtDriverStatus @default(ACTIVE)
  licenseNumber    String?
  licenseState     String?
  licenseExpiresAt DateTime?
  cprExpiresAt     DateTime?
  hireDate         DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  worker           Worker?          @relation(fields: [workerId], references: [id], onDelete: SetNull)
  trips            Trip[]
  documents        NemtDocument[]
  incidents        NemtIncident[]
  scores           DriverScore[]

  @@index([status])
  @@index([licenseExpiresAt])
  @@index([cprExpiresAt])
}

model Vehicle {
  id                    String                   @id @default(cuid())
  name                  String
  status                NemtVehicleStatus        @default(ACTIVE)
  vin                   String?                  @unique
  plateNumber           String?
  plateState            String?
  make                  String?
  model                 String?
  year                  Int?
  capacityAmbulatory    Int                      @default(0)
  capacityWheelchair    Int                      @default(0)
  odometer              Int?
  registrationExpiresAt DateTime?
  insuranceExpiresAt    DateTime?
  inspectionDueAt       DateTime?
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  trips                 Trip[]
  documents             NemtDocument[]
  maintenance           NemtVehicleMaintenance[]
  incidents             NemtIncident[]

  @@unique([plateState, plateNumber])
  @@index([status])
  @@index([registrationExpiresAt])
  @@index([insuranceExpiresAt])
  @@index([inspectionDueAt])
}

model Facility {
  id            String   @id @default(cuid())
  name          String
  mtmFacilityId String?  @unique
  facilityType  String?
  phone         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pickupTrips   Trip[]   @relation("TripPickupFacility")
  dropoffTrips  Trip[]   @relation("TripDropoffFacility")

  @@index([name])
  @@index([isActive])
}

model Trip {
  id                 String                  @id @default(cuid())
  tripNumber         String?                 @unique
  broker             NemtBroker              @default(MTM)
  status             NemtTripStatus          @default(NEW)
  passengerName      String
  passengerPhone     String?
  memberId           String?
  pickupFacilityId   String?
  dropoffFacilityId  String?
  pickupAddress      String
  pickupLatitude     Decimal?                @db.Decimal(10, 7)
  pickupLongitude    Decimal?                @db.Decimal(10, 7)
  dropoffAddress     String
  dropoffLatitude    Decimal?                @db.Decimal(10, 7)
  dropoffLongitude   Decimal?                @db.Decimal(10, 7)
  scheduledPickupAt  DateTime
  appointmentAt      DateTime?
  estimatedDropoffAt DateTime?
  actualPickupAt     DateTime?
  actualDropoffAt    DateTime?
  assignedDriverId   String?
  vehicleId          String?
  requiresWheelchair Boolean                 @default(false)
  requiresEscort     Boolean                 @default(false)
  estimatedMileage   Decimal?                @db.Decimal(8, 2)
  actualMileage      Decimal?                @db.Decimal(8, 2)
  billableMileage    Decimal?                @db.Decimal(8, 2)
  fareAmount         Decimal                 @default(0) @db.Decimal(12, 2)
  notes              String?
  cancellationReason String?
  noShowReason       String?
  metadata           Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  pickupFacility     Facility?               @relation("TripPickupFacility", fields: [pickupFacilityId], references: [id], onDelete: SetNull)
  dropoffFacility    Facility?               @relation("TripDropoffFacility", fields: [dropoffFacilityId], references: [id], onDelete: SetNull)
  assignedDriver     Driver?                 @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  vehicle            Vehicle?                @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  externalReferences ExternalTripReference[]
  invoiceLines       NemtInvoiceLine[]
  documents          NemtDocument[]
  incidents          NemtIncident[]

  @@index([broker, scheduledPickupAt])
  @@index([status, scheduledPickupAt])
  @@index([assignedDriverId, scheduledPickupAt])
  @@index([vehicleId, scheduledPickupAt])
  @@index([pickupFacilityId])
  @@index([dropoffFacilityId])
  @@index([memberId, scheduledPickupAt])
}

model ExternalTripReference {
  id         String             @id @default(cuid())
  tripId     String
  source     NemtExternalSystem
  externalId String
  rawPayload Json?
  importedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  trip       Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([tripId])
}

model NemtInvoice {
  id              String            @id @default(cuid())
  invoiceNumber   String?           @unique
  status          NemtInvoiceStatus @default(DRAFT)
  broker          NemtBroker        @default(MTM)
  totalAmount     Decimal           @default(0) @db.Decimal(12, 2)
  submittedAt     DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  paidAt          DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  lineItems       NemtInvoiceLine[]

  @@index([status, createdAt])
  @@index([broker, createdAt])
}

model NemtInvoiceLine {
  id        String      @id @default(cuid())
  invoiceId String
  tripId    String
  amount    Decimal     @default(0) @db.Decimal(12, 2)
  mileage   Decimal?    @db.Decimal(8, 2)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  invoice   NemtInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  trip      Trip        @relation(fields: [tripId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, tripId])
  @@index([tripId])
}

model NemtDocument {
  id             String             @id @default(cuid())
  driverId       String?
  vehicleId      String?
  tripId         String?
  type           NemtDocumentType
  status         NemtDocumentStatus @default(VALID)
  title          String
  documentNumber String?
  fileUrl        String?
  issuedAt       DateTime?
  expiresAt      DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  driver         Driver?            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip           Trip?              @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([driverId, type])
  @@index([vehicleId, type])
  @@index([tripId, type])
  @@index([status, expiresAt])
}

model NemtVehicleMaintenance {
  id          String              @id @default(cuid())
  vehicleId   String
  serviceType NemtMaintenanceType @default(ROUTINE)
  serviceDate DateTime?
  dueDate     DateTime?
  odometer    Int?
  cost        Decimal?            @db.Decimal(12, 2)
  vendor      String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  vehicle     Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, dueDate])
  @@index([serviceType, dueDate])
}

model NemtIncident {
  id              String             @id @default(cuid())
  tripId          String?
  driverId        String?
  vehicleId       String?
  type            NemtIncidentType
  status          NemtIncidentStatus @default(OPEN)
  title           String
  description     String?
  reportedBy      String?
  resolutionNotes String?
  occurredAt      DateTime           @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  trip            Trip?              @relation(fields: [tripId], references: [id], onDelete: SetNull)
  driver          Driver?            @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle         Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([status, occurredAt])
  @@index([type, occurredAt])
  @@index([driverId, occurredAt])
  @@index([vehicleId, occurredAt])
  @@index([tripId])
}

model DriverScore {
  id                   String   @id @default(cuid())
  driverId             String
  month                DateTime
  onTimePercentage     Decimal  @default(100) @db.Decimal(5, 2)
  customerComplaints   Int      @default(0)
  attendancePercentage Decimal  @default(100) @db.Decimal(5, 2)
  noShowResponsibility Int      @default(0)
  rideCompletionRate   Decimal  @default(100) @db.Decimal(5, 2)
  monthlyScore         Decimal  @default(100) @db.Decimal(5, 2)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  driver               Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, month])
  @@index([month])
  @@index([monthlyScore])
}
